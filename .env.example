# Mahir AI OS Configuration Example
# Copy this to .env and fill in your actual keys

APP_NAME="Mahir AI OS"
APP_VERSION="AR1"
APP_ENV=development  # development, staging, production, test
LOG_LEVEL=INFO

# Provider API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=

# Default Provider Settings
ACTIVE_PROVIDER=openai
MODEL_NAME=gpt-5.5
PROVIDER_TIMEOUT_SECONDS=30.0
TEMPERATURE=0.7

# Database Configuration
DB_BACKEND=sqlite
SQLITE_PATH=./database/mahir.db
POSTGRES_DSN=

# Memory Configuration
MEMORY_SHORT_TERM_TTL=3600
MEMORY_LONG_TERM_ENABLED=false
MEMORY_RETENTION_DAYS=30

# MCP Configuration
MCP_ENABLED=false
MCP_SERVER_URLS=
